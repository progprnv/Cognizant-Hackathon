# ─────────────────────────────────────────────
# .env.example  —  copy to .env and fill values
# ─────────────────────────────────────────────

# App
APP_NAME="FraudShield AI"
APP_ENV=development          # development | production
DEBUG=true
SECRET_KEY=your-super-secret-jwt-key-change-in-prod

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://fraud_user:fraud_pass@localhost:5432/fraud_db

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Fraud Thresholds
RISK_LOW_THRESHOLD=35
RISK_HIGH_THRESHOLD=70
AUTOFILL_TIME_THRESHOLD_MS=300   # < 300 ms = suspected autofill
MIN_HUMAN_TYPING_INTERVAL_MS=50  # keystroke interval floor

# Geo-IP (free service; replace with MaxMind in prod)
GEOIP_API_URL=http://ip-api.com/json

# Alert webhook (Slack / Teams / custom)
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ
